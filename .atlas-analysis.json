  "keyFeatures": [
    "Resume-based personalized question generation using RAG",
    "Real-time speech-to-text interview streaming with WebSocket",
    "Adaptive difficulty tracking across DBMS, OOP, and OS topics",
    "AI-powered coding practice with SQL and Pandas problems",
    "Speech analysis with pitch stability and fluency metrics",
    "FAISS vector search for knowledge base retrieval",
    "User mastery tracking with concept-level progress",
    "Mistral AI-powered answer evaluation and feedback"
  ],
  "publicApiSurface": [
    "/api/auth/signup - User registration",
    "/api/auth/login - User authentication",
    "/api/auth/logout - Session termination",
    "/api/profile - User profile management",
    "/api/resume/upload - Resume file upload",
    "/api/resume/analyze - Extract and index resume data",
    "/api/interview/start - Initialize interview session",
    "/api/interview/questions - Generate personalized questions",
    "/api/interview/evaluate - Evaluate answer with AI feedback",
    "/api/interview/history - Retrieve past sessions",
    "/api/rag/query - Query technical knowledge base",
    "/api/coding/generate - Generate coding problems",
    "/api/coding/evaluate - Evaluate code submission",
    "/api/mastery/stats - Get user mastery statistics",
    "WebSocket: join_interview - Start real-time session",
    "WebSocket: audio_chunk - Stream audio data",
    "WebSocket: stop_recording - End session with analysis"
  ]
